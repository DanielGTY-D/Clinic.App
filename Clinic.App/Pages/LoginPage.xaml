<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Clinic.App.Pages.Login"
             Title="Login">
    <VerticalStackLayout
        Padding="20"
        >
        <Label 
            Text="Inicia Sesion"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />

        <Border
            StrokeShape="10"
            IsVisible="false"
            BackgroundColor="red"
            x:Name="ErrorMessageContainer"
            Padding="8"
            Margin="0, 10"
            >
            <Label x:Name="ErrorMessageLabel" VerticalTextAlignment="Center" TextColor="white"/>
        </Border>

        <Label Text="Correo" />
        <Entry x:Name="EntryEmail" Placeholder="correo@correo.com" />

        <Label Text="Password" />
        <Entry x:Name="EntryPassword" Placeholder="********"/>

        <HorizontalStackLayout 
            Spacing="10"
            Margin="10, 0, 0, 0"
            >
            <Button
                Text="Login"
                Clicked="OnClickedLogin"
                />
            <Button
                Text="Register"
                Clicked="OnClickedRegister"
                />
        </HorizontalStackLayout>

        
    </VerticalStackLayout>
</ContentPage>