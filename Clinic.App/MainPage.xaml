<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Clinic.App.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="16,20" Spacing="12">

            <!-- ✅ Header: perfil del usuario (tappable) -->
            <Border Padding="14,12"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}"
                    StrokeThickness="0.5"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPerfilTapped"/>
                </Border.GestureRecognizers>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                    <!-- Avatar con iniciales -->
                    <Border Grid.Column="0"
                            WidthRequest="46"
                            HeightRequest="46"
                            BackgroundColor="#E6F1FB">
                        <Border.StrokeShape>
                            <Ellipse/>
                        </Border.StrokeShape>
                        <Label x:Name="AvatarLabel"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#0C447C"/>
                    </Border>

                    <!-- Nombre y datos básicos -->
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Bienvenido"
                               FontSize="11"
                               TextColor="Gray"/>
                        <Label x:Name="UserNameLabel"
                               FontSize="15"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation"/>
                        <HorizontalStackLayout Spacing="8">
                            <Label x:Name="BloodGroupLabel"
                                   FontSize="12"
                                   TextColor="Gray"/>
                            <Label Text="·" FontSize="12" TextColor="Gray"/>
                            <Label x:Name="PhoneLabel"
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <!-- Flecha -->
                    <Label Grid.Column="2"
                           Text="›"
                           FontSize="24"
                           TextColor="Gray"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>
            <!-- Fin header -->

            <!-- Etiqueta sección -->
            <Label Text="Tus citas"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="Gray"
                   Margin="4,8,0,0"
                   CharacterSpacing="1"/>

            <!-- Estado vacío -->
            <StackLayout x:Name="EmptyState"
                         IsVisible="True"
                         HorizontalOptions="Center"
                         VerticalOptions="Center"
                         Padding="20"
                         Spacing="12">

                <Border BackgroundColor="{AppThemeBinding Light=#F1EFE8, Dark=#2C2C2A}"
                        WidthRequest="72"
                        HeightRequest="72"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <Ellipse/>
                    </Border.StrokeShape>
                    <Image Source="calendar_off.png"
                           WidthRequest="32"
                           HeightRequest="32"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Label Text="Sin citas programadas"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <Label Text="No tienes citas próximas. Agenda una con tu médico."
                       FontSize="13"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"/>

                <Button Text="+ Agendar cita"
                        Clicked="OnAgendarClicked"
                        HorizontalOptions="Center"
                        Padding="16,10"/>

            </StackLayout>

            <!-- Lista de citas -->
            <CollectionView x:Name="AppointmentsCollection" IsVisible="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="15"
                                Stroke="LightGray" StrokeThickness="0.5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>

                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Paciente -->
                                <Label Grid.Row="0"
                                       Text="{Binding Patient.User.FirstName, StringFormat='👤 {0}'}"
                                       FontAttributes="Bold"
                                       FontSize="Medium"/>

                                <!-- Doctor y Especialidad -->
                                <HorizontalStackLayout Grid.Row="1" Spacing="4">
                                    <Label Text="{Binding Doctor.Employee.User.FirstName, StringFormat='🩺 Dr. {0}'}"
                                           FontSize="Small" TextColor="Gray"/>
                                    <Label Text="·" FontSize="Small" TextColor="Gray"/>
                                    <Label Text="{Binding Doctor.Speciality.Name}"
                                           FontSize="Small" TextColor="DarkBlue"/>
                                </HorizontalStackLayout>

                                <!-- Fecha, Hora, Consultorio -->
                                <HorizontalStackLayout Grid.Row="2" Spacing="4">
                                    <Label Text="{Binding AppointmentDate, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                           FontSize="Small"/>
                                    <Label Text="|" FontSize="Small" TextColor="Gray"/>
                                    <Label Text="{Binding StartTime, StringFormat='🕐 {0}'}"
                                           FontSize="Small"/>
                                    <Label Text="|" FontSize="Small" TextColor="Gray"/>
                                    <Label Text="{Binding ConsultingRoom.Number, StringFormat='🏥 Cons. {0}'}"
                                           FontSize="Small"/>
                                </HorizontalStackLayout>

                                <!-- Separador -->
                                <BoxView Grid.Row="3"
                                         HeightRequest="0.5"
                                         Color="LightGray"
                                         Margin="0,4"/>

                                <!-- Estado de Pago -->
                                <HorizontalStackLayout Grid.Row="4" Spacing="6">
                                    <BoxView WidthRequest="8" HeightRequest="8"
                                             CornerRadius="4" VerticalOptions="Center">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding IsPaid}" Value="true">
                                                <Setter Property="Color" Value="Green"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding IsPaid}" Value="false">
                                                <Setter Property="Color" Value="Red"/>
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                    <Label FontSize="Small" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPaid}" Value="true">
                                                <Setter Property="Text" Value="Pagado"/>
                                                <Setter Property="TextColor" Value="Green"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsPaid}" Value="false">
                                                <Setter Property="Text" Value="Pendiente de pago"/>
                                                <Setter Property="TextColor" Value="Red"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>